{
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "booking": {
        "ClusterId": "bookingCluster",
        "Match": { "Path": "/api/bookings/{**catch-all}" }
      },
      "venue": {
        "ClusterId": "venueCluster",
        "Match": { "Path": "/api/venues/{**catch-all}" }
      },
      "notification": {
        "ClusterId": "notificationCluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001/" }
        }
      },
      "bookingCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002/" }
        }
      },
      "venueCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5003/" }
        }
      },
      "notificationCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5004/" }
        }
      }
    }
  }
}